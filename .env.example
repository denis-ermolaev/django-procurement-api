# 1. База данных ----
DB_NAME=api
DB_USER=api
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# 1.1. Тестовая база данных ----
DB_TEST_NAME=api_test

# 2. Django ----
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.137.2
# Для reverse-proxy (code-server): доверять заголовку X-Forwarded-Proto
DJANGO_USE_X_FORWARDED_HOST=True
# Origin-ы для CSRF (code-server: HTTPS с нестандартным портом)
DJANGO_CSRF_TRUSTED_ORIGINS=
# Префикс reverse proxy, добавляется ко всем сгенерированным Django URL
# Пусто — прямая разработка; /proxy/8000 — code-server
DJANGO_PROXY_SCRIPT_NAME=/proxy/8000

# 3. Email ----
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_ADMIN_EMAILS=admin@example.com

# 4. Rate limiting (DRF Throttling) ----
DJANGO_THROTTLE_ANON=20/minute
DJANGO_THROTTLE_USER=60/minute
DJANGO_THROTTLE_SHOP_REGISTER=5/minute
DJANGO_THROTTLE_SHOP_IMPORT=10/minute
DJANGO_THROTTLE_ORDER_CONFIRM=10/minute

# 5. Кэширование ----
# Для single-instance разработки — locmem (не требует Redis).
# Для multi-instance — раскомментировать redis:
# DJANGO_CACHE_BACKEND=redis
# DJANGO_REDIS_URL=redis://redis:6379/1
DJANGO_CACHE_BACKEND=locmem
DJANGO_REDIS_URL=redis://redis:6379/1
DJANGO_CACHE_TIMEOUT_CATALOG=300

# 5a. RQ (асинхронная очередь задач) ----
DJANGO_RQ_HOST=redis
DJANGO_RQ_PORT=6379
DJANGO_RQ_DB=1

# 6. Логгинг ----
DJANGO_LOGGING_ENABLED=False
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_MODULES=
DJANGO_LOG_SQL=False

# 7. Прокси для сборки Docker-образа ----
# Раскомментируй и укажи адрес корпоративного прокси, если требуется
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,.local
